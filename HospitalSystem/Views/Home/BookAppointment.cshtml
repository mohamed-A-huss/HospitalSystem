@model IEnumerable<Doctor>
<h1>Book Appointment</h1>

<form method="get" asp-action="BookAppointment" class="row mb-4">

    <div class="col-md-4">
        <input type="text"
               name="searchName"
               value="@ViewBag.SearchName"
               class="form-control"
               placeholder="Search by doctor name">
    </div>

    <div class="col-md-4">
    <select name="specialization" class="form-control">
        <option value="">All Specializations</option>
        @foreach (var spec in ViewBag.Specializations as List<string>)
            {
                if (ViewBag.specialization == @spec)
                    {
                    <option value="@spec" selected>@spec</option>

                    }
                    else
                    {
                    <option value="@spec" >@spec</option>
                        
                    }
        }
    </select>
</div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>

</form>
@if (!Model.Any())
{
    <div class="alert alert-warning">
        No doctors found with this search.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card ">
                    <img class="card-img" src="~/Images/Doctors/doctor@(item.Id).jpg" style="width: 100%; height: 350px;" alt="Doctor Image">
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text">Specialization: @item.Specialization</p>
                            <a href="/Home/CompleteAppointment?doctorId=@item.Id" class="btn btn-primary">Book Appointment</a>
                        </div>
                    </div>
                </div>
            }
        </div>
}
<nav>
        <ul class="pagination justify-content-center">

            <!-- Previous -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="BookAppointment" asp-route-page="@(ViewBag.CurrentPage - 1)">Previous</a>
            </li>

            <!-- Page Numbers -->
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="BookAppointment" asp-route-page="@i">@i</a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages || ViewBag.TotalPages == 0 ? "disabled" : "")">
                <a class="page-link" asp-action="BookAppointment" asp-route-page="@(ViewBag.CurrentPage + 1)">Next</a>
            </li>

        </ul>
    </nav>
